{
  "name": "ipa-system-starter",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings=0",
    "lint:a11y:ci": "eslint -c eslint.a11y-ci.config.js src/components/delegations/SharedDelegationForm.tsx src/components/tasks/SharedTaskList.tsx src/pages/admin/MasterDataPage.tsx src/components/layout/v2/Header.tsx src/components/layout/v2/Sidebar.tsx src/components/layout/v2/AppShell.tsx --max-warnings=0",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=line",
    "guard:ui-placeholder": "node scripts/check_placeholder_actions.cjs",
    "guard:vi-diacritics": "node scripts/check_vietnamese_diacritics.cjs",
    "preview": "vite preview",
    "generate:icon-types": "node scripts/generateIconType.mjs",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {if (e.code !== 'MODULE_NOT_FOUND') throw e}\""
